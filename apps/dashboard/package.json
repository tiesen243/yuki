  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun with-env next dev -p 3001",
    "build": "bun with-env next build",
    "start": "bun with-env next start",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
